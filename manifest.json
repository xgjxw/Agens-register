{
  "manifest_version": 3,
  "name": "Agens 发卡机",
  "version": "0.1.3",
  "description": "自动注册 Agnes/RedFox 账号、提取验证码、创建 API Key 并导出结果。",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "browsingData",
    "downloads"
  ],
  "host_permissions": [
    "https://tempmail.ing/*",
    "https://mail.cx/*",
    "https://platform.agnes-ai.com/*",
    "https://redfox.hk/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Agens 发卡机",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tempmail.ing/*",
        "https://mail.cx/*"
      ],
      "js": [
        "content/tempmail.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://platform.agnes-ai.com/*"
      ],
      "js": [
        "content/agnes.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://redfox.hk/*"
      ],
      "js": [
        "content/redfox.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
